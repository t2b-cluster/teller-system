{
  "id": null,
  "uid": "infra-overview",
  "title": "Infrastructure Overview - Cluster & Services",
  "tags": ["infrastructure", "teller"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "All Services Status",
      "type": "stat",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Process CPU Usage (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total[5m]) * 100", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "fillOpacity": 20, "lineWidth": 2 } }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Process Memory RSS (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes", "custom": { "fillOpacity": 20, "lineWidth": 2 } }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Process Heap Used (Node.js)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes / 1024 / 1024", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes", "custom": { "fillOpacity": 15 } }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Node.js Event Loop Lag (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Active Handles (Node.js)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nodejs_active_handles_total", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 } }, "overrides": [] }
    },
    {
      "id": 7,
      "title": "Redis Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_memory_used_bytes / 1024 / 1024", "legendFormat": "Redis Memory (MB)" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes", "custom": { "fillOpacity": 20 } }, "overrides": [] }
    },
    {
      "id": 8,
      "title": "Redis Connected Clients",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_connected_clients", "legendFormat": "Clients" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] }
    },
    {
      "id": 9,
      "title": "Redis Commands/sec",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "cmd/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15 } }, "overrides": [] }
    },
    {
      "id": 10,
      "title": "Redis Keyspace Hit Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total) * 100", "legendFormat": "Hit Rate" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] }
        },
        "overrides": []
      }
    }
  ]
}
