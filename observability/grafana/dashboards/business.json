{
  "id": null,
  "uid": "business-metrics",
  "title": "Business Metrics - Daily Operations",
  "tags": ["business", "teller"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 39,
  "version": 10,
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "✅ Transfers Completed", "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_transfer_total{status=\"completed\"}) or vector(0)", "legendFormat": "Completed" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    },
    {
      "id": 2, "title": "⏳ Transfers Pending", "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_transfer_total{status=\"pending\"}) or vector(0)", "legendFormat": "Pending" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "yellow" } }, "overrides": [] }
    },
    {
      "id": 3, "title": "❌ Transfers Failed", "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_transfer_total{status=\"failed\"}) or vector(0)", "legendFormat": "Failed" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] }
    },
    {
      "id": 4, "title": "Transfer Status Over Time", "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(teller_transfer_total{status=\"completed\"}) or vector(0)", "legendFormat": "Completed" },
        { "expr": "sum(teller_transfer_total{status=\"pending\"}) or vector(0)", "legendFormat": "Pending" },
        { "expr": "sum(teller_transfer_total{status=\"failed\"}) or vector(0)", "legendFormat": "Failed" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 5, "title": "🏦 New Accounts", "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_account_created_total) or vector(0)", "legendFormat": "Accounts" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] }
    },
    {
      "id": 6, "title": "Account Openings Over Time", "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_account_created_total) or vector(0)", "legendFormat": "New Accounts" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "custom": { "fillOpacity": 25 } }, "overrides": [] }
    },
    {
      "id": 7, "title": "📊 Total Transactions", "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_transactions_total) or vector(0)", "legendFormat": "Total" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] }
    },
    {
      "id": 8, "title": "Transactions Completed", "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_transactions_total{status=\"completed\"}) or vector(0)", "legendFormat": "Completed" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    },
    {
      "id": 9, "title": "Transactions Failed", "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_transactions_total{status=\"failed\"}) or vector(0)", "legendFormat": "Failed" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] }
    },
    {
      "id": 10, "title": "Transfer Amount Volume (THB)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_transfer_amount_total) or vector(0)", "legendFormat": "THB Total" }],
      "fieldConfig": { "defaults": { "unit": "currencyTHB", "custom": { "fillOpacity": 25 } }, "overrides": [] }
    },
    {
      "id": 12, "title": "🔐 Login Success", "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_auth_login_total{status=\"success\"}) or vector(0)", "legendFormat": "Success" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    },
    {
      "id": 13, "title": "🔐 Login Failed", "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_auth_login_total{status=\"failed\"}) or vector(0)", "legendFormat": "Failed" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] }
    },
    {
      "id": 14, "title": "Reconciliation Matched", "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_reconciliation_total{result=\"matched\"}) or vector(0)", "legendFormat": "Matched" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    },
    {
      "id": 15, "title": "Reconciliation Mismatched", "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(teller_reconciliation_total{result=\"mismatched\"}) or vector(0)", "legendFormat": "Mismatched" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] }
    }
  ]
}
